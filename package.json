{
  "name": "{{crate_name}}",
  "private": true,
  "version": "0.0.0",
  "description": "{{project_description}}",
  "author": "{{author}}",
  "license": "GPL-3.0-or-later",
  "repository": "{{repository}}",
  "type": "module",
  "scripts": {
    {% if backend == "actix" -%}
    "dev": "vite",
    "build-frontend": "tsc && vite build",
    "build-api": "cargo build --release",
    "build": "npm run build-frontend && npm run build-api",
    "run-api": "cargo run",
    "watch": "cargo watch -q -c -w src-actix/ -x run",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
    {%- elsif backend == "tauri" -%}
    "dev": "vite",
    "build": "tsc && vite build",
    "build and preview": "npm run build && npm run preview",
    "tauri-dev": "tauri dev",
    "tauri-build": "tauri build"
    {%- elsif backend == "vanilla" -%}
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
    {%- elsif backend == "nodejs" -%}
    "dev": "concurrently \"vite\" \"nodemon server/index.js\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js"
    {%- elsif backend == "php" -%}
    "dev": "vite",
    "build": "tsc && vite build"
    {%- endif %}
  },
  "dependencies": {
    "@heroui/react": "2.8.5",
    "@iconify-icon/react": "2.3.0",
    "framer-motion": "12.19.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.1.3"{% if backend == "nodejs" %},
    "express": "4.21.2"{% endif %}{% if backend == "tauri" %},
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2"{% endif %}
  },
  "devDependencies": {
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.21.0",
    "@typescript-eslint/parser": "8.21.0",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.16",
    "eslint": "9.18.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.18",
    "postcss": "8.4.31",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vite": "7.1.11"{% if backend == "nodejs" %},
    "@types/express": "5.0.0",
    "concurrently": "9.1.2",
    "nodemon": "3.1.9"{% endif %}{% if backend == "php" %},
    "laravel-vite-plugin": "1.1.1"{% endif %}{% if backend == "tauri" %},
    "@tauri-apps/cli": "^2",
    "sass": "1.83.4",
    "sass-loader": "16.0.4",
    "postcss-import": "15.1.0"{% endif %}
  }{% if backend == "tauri" %},
  "engines": {
      {% if package_manager == "npm" %}
      "npm": ">=10.2.3"
      {% elsif package_manager == "yarn" %}
      "yarn": ">=1.22.19"
      {% elsif package_manager == "pnpm" %}
      "pnpm": ">=8.13.1"
      {% endif %}
  }{% endif %}
}
